NODE_ENV=development
PORT=3001

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site_survey
DB_USER=survey_user
DB_PASSWORD=survey_pass_2024
DB_SSL=false

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8081,http://10.0.2.2:8081,http://10.1.0.130:8081,exp://10.1.0.130:8081,exp://10.0.2.2:8081,http://10.0.1.105:8081,exp://10.0.1.105:8081,http://10.0.0.82:8081,exp://10.0.0.82:8081

# Auth token settings
JWT_SECRET=change_this_for_prod
JWT_EXPIRES_IN=12h

# Sign-in lockout policy
SIGNIN_MAX_FAILURES=5
SIGNIN_WINDOW_MINUTES=15
SIGNIN_LOCK_MINUTES=15

# Users route throttling
USERS_REGISTER_MAX_REQUESTS=8
USERS_REGISTER_WINDOW_MINUTES=15
USERS_ME_MAX_REQUESTS=120
USERS_ME_WINDOW_MINUTES=1
