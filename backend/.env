NODE_ENV=development
PORT=3001

# PostgreSQL connection
DATABASE_URL=postgres://survey_user:survey_pass_2024@localhost:5432/site_survey?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site_survey
DB_USER=survey_user
DB_PASSWORD=survey_pass_2024
DB_SSL=false

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8081,http://10.0.2.2:8081,http://10.1.0.130:8081,exp://10.1.0.130:8081,exp://10.0.2.2:8081,http://10.0.1.105:8081,exp://10.0.1.105:8081,http://10.0.0.82:8081,exp://10.0.0.82:8081,http://192.168.137.100:8081,exp://192.168.137.100:8081

# Auth token settings
JWT_SECRET=change_this_for_prod
JWT_EXPIRES_IN=12h

# Sign-in lockout policy
SIGNIN_MAX_FAILURES=5
SIGNIN_WINDOW_MINUTES=15
SIGNIN_LOCK_MINUTES=15

# Users route throttling
USERS_REGISTER_MAX_REQUESTS=8
USERS_REGISTER_WINDOW_MINUTES=15
USERS_ME_MAX_REQUESTS=120
USERS_ME_WINDOW_MINUTES=1
SOLARPRO_API_URL=https://solarpro-dev.vercel.app
# MOBILE_SERVICE_API_KEY must match MOBILE_SERVICE_API_KEY in Vercel dashboard.
# Copy the value from Vercel -> solarpro-dev -> Settings -> Environment Variables -> MOBILE_SERVICE_API_KEY
# and paste it here AND set it in the Render dashboard under the same name.
MOBILE_SERVICE_API_KEY=PASTE_VERCEL_MOBILE_SERVICE_API_KEY_HERE
SOLARPRO_API_KEY=PASTE_VERCEL_MOBILE_SERVICE_API_KEY_HERE
SOLARPRO_HANDOFF_SECRET=prod_handoff_secret_2026_rotate_me

# ── Outbound webhook to SolarPro ──────────────────────────────────────────────
# URL of SolarPro's survey webhook receiver endpoint (no trailing slash).
# webhookService.ts delivers survey.completed events here.
# Production: https://solarpro-dev.vercel.app/api/webhooks/survey-complete
SOLARPRO_WEBHOOK_URL=https://solarpro-dev.vercel.app/api/webhooks/survey-complete

# HMAC-SHA256 shared secret used to sign outbound webhook payloads.
# Must match SURVEY_WEBHOOK_SECRET in the SolarPro Vercel environment.
SURVEY_WEBHOOK_SECRET=prod_handoff_secret_2026_rotate_me

# Accept survey webhooks and return 202 (pipeline is live).
WEBHOOK_PRE_INGEST_ACCEPT_202=true
