{
  "name": "site-survey-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go --tunnel --clear",
    "start:dev-client": "expo start --dev-client --clear",
    "android": "node ./scripts/run-android-safe.js",
    "android:emulator": "node ./scripts/start-emulator-and-run.js",
    "android:diagnose": "node ./scripts/diagnose-android.js",
    "android:reset-adb": "node ./scripts/reset-adb.js",
    "android:test-device": "node ./scripts/test-device-connection.js",
    "android:unsafe": "expo run:android",
    "android:check-tooling": "node ./scripts/check-android-tooling.js",
    "android:prebuild": "expo prebuild --platform android",
    "android:eas": "npx eas-cli build --platform android --profile development",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "deploy": "npx eas-cli update --branch preview --environment preview",
    "deploy-prod": "npx eas-cli update --branch main --environment production",
    "build": "npx eas-cli build --platform all --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.15.2",
    "expo": "^56.0.0",
    "expo-application": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-image-manipulator": "~56.0.13",
    "expo-image-picker": "~56.0.12",
    "expo-linking": "~56.0.11",
    "expo-location": "~56.0.12",
    "expo-network": "~56.0.4",
    "expo-router": "~56.2.5",
    "expo-sharing": "~56.0.12",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.15",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "@expo/ngrok": {
      "uuid": "11.1.1"
    },
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-arrow-functions": "^7.25.9",
    "@babel/plugin-transform-block-scoped-functions": "^7.25.9",
    "@babel/plugin-transform-block-scoping": "^7.28.5",
    "@babel/plugin-transform-classes": "^7.25.9",
    "@babel/plugin-transform-computed-properties": "^7.25.9",
    "@babel/plugin-transform-destructuring": "^7.25.9",
    "@babel/plugin-transform-for-of": "^7.25.9",
    "@babel/plugin-transform-function-name": "^7.25.9",
    "@babel/plugin-transform-literals": "^7.25.9",
    "@babel/plugin-transform-new-target": "^7.25.9",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.25.9",
    "@babel/plugin-transform-object-super": "^7.25.9",
    "@babel/plugin-transform-optional-chaining": "^7.25.0",
    "@babel/plugin-transform-parameters": "^7.25.9",
    "@babel/plugin-transform-regenerator": "^7.28.4",
    "@babel/plugin-transform-shorthand-properties": "^7.25.9",
    "@babel/plugin-transform-spread": "^7.25.9",
    "@babel/plugin-transform-sticky-regex": "^7.25.9",
    "@babel/plugin-transform-template-literals": "^7.25.9",
    "@babel/plugin-transform-typeof-symbol": "^7.25.9",
    "@babel/plugin-transform-unicode-regex": "^7.25.9",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.14",
    "@types/uuid": "^10.0.0",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^10.2.1",
    "typescript": "~6.0.3"
  }
}
