{
  "expo": {
    "name": "Site Survey",
    "slug": "site-survey-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitesurvey.mobile",
      "config": {
        "googleMapsApiKey": "AIzaSyBcXQC-i7s2TJz8PNOM1OhiU-sEhPR41wE"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Site Survey needs your location to record GPS coordinates for each survey.",
        "NSCameraUsageDescription": "Site Survey needs camera access to capture site photos.",
        "NSPhotoLibraryUsageDescription": "Site Survey needs photo library access to attach photos to surveys.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sitesurvey.mobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBcXQC-i7s2TJz8PNOM1OhiU-sEhPR41wE"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 16
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Site Survey needs your location to record GPS coordinates."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Site Survey needs photo library access.",
          "cameraPermission": "Site Survey needs camera access."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://site-survey-api-bpyz.onrender.com",
      "router": {},
      "eas": {
        "projectId": "aed7aae8-7d55-47e1-8850-c6b0040c99b5"
      }
    },
    "owner": "kilby",
    "updates": {
      "url": "https://u.expo.dev/aed7aae8-7d55-47e1-8850-c6b0040c99b5",
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.0"
  }
}
