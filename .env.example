# ─────────────────────────────────────────────────────────────────
# Repo-root .env  –  copy to .env and fill in real values
# Never commit the real .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Render deploy (backend) ───────────────────────────────────────
# API key:    https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx

# Service ID: open site-survey-api in the Render dashboard; copy
# the srv-xxx portion from the URL.
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# ── SolarPro partner API ──────────────────────────────────────────
# Base URL of Raymond's SolarPro backend (no trailing slash).
# Required for the client/project cascade picker in the mobile app.
SOLARPRO_API_URL=https://your-solarpro-backend.com

# Optional bearer token if Raymond's API requires service-to-service auth.
SOLARPRO_API_KEY=

# ── EAS / Expo ────────────────────────────────────────────────────
# Set automatically by Expo tooling; only needed if running eas
# commands outside of an Expo-authenticated shell.
# EXPO_TOKEN=

